NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Agent API (/api/v1/*) + Issuing metadata (optional if STRIPE_SKIP_ISSUING=1)
STRIPE_SECRET_KEY=
STRIPE_SKIP_ISSUING=1
APPROVAL_BASE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: allow POST /api/v1/approvals + MCP approve_pending tool (discouraged in prod)
# MANDATE_ALLOW_AGENT_APPROVAL=1

# Optional: Agent REST API rate limits (requests per rolling minute per bucket; 0 = unlimited that bucket)
# In-memory per Cloudflare isolate — protects Stripe/Supabase from accidental hot-loops.
# AGENT_API_IP_MAX_PER_MIN=600
# AGENT_API_READ_LIGHT_PER_MIN=120
# AGENT_API_READ_HEAVY_PER_MIN=40
# AGENT_API_WRITE_PER_MIN=25

# Optional: dashboard “new MCP key” rotations per user per hour
# MCP_KEY_ROTATE_MAX_PER_HOUR=8
